# Groq API Key — get yours free at https://console.groq.com
# Uses llama-3.3-70b-versatile model.
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/friday

# JWT secret — change this to a long random string in production
JWT_SECRET=change-this-to-a-random-secret

# TVA Timesheet Auth (iamneo) — employees log in with their timesheet credentials
# Set to the base URL of the timesheet backend (no trailing slash)
# Example: TVA_AUTH_URL=http://localhost:5000  (local)
#          TVA_AUTH_URL=https://your-timesheet-backend.onrender.com  (production)
TVA_AUTH_URL=http://localhost:5000

# MCP internal shared secret (must match both services)
MCP_SECRET=friday-mcp-2025
